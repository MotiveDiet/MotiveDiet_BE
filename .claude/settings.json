{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.agents/scripts/rule-matcher.py\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "적용 룰 확인 중"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.agents/scripts/quality-gate.py\" 2>/dev/null || true",
            "timeout": 180,
            "statusMessage": "품질 게이트 검사 중"
          }
        ]
      }
    ]
  }
}
